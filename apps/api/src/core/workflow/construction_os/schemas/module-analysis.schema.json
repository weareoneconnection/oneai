{
  "$id": "constructionOsModuleAnalysisV1",
  "type": "object",
  "additionalProperties": true,
  "required": ["status", "executiveSummary", "metrics", "recommendations"],
  "properties": {
    "status": { "type": "string", "enum": ["ok", "warning", "critical"] },
    "executiveSummary": { "type": "string", "minLength": 1, "maxLength": 6000 },
    "metrics": { "type": "object", "additionalProperties": true },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "risks": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["title", "severity", "explanation"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "explanation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "suggestedActions": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["action", "ownerRole", "dueInDays", "automatable"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "ownerRole": { "type": "string", "minLength": 1 },
          "dueInDays": { "type": "number" },
          "automatable": { "type": "boolean" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
