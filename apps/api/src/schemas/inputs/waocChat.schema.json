{
  "$id": "waocChatInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["message"],
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "context": {
      "type": "string",
      "enum": ["community", "mission", "philosophy", "general"],
      "default": "general"
    },
    "lang": {
      "type": "string",
      "enum": ["en", "zh", "mixed"],
      "default": "en"
    },
    "emotionHint": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "greeting_morning",
            "greeting_night",
            "stress",
            "anger",
            "celebrate",
            "gratitude",
            "apology"
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "recentMessages": {
      "type": "string",
      "maxLength": 20000,
      "default": ""
    },
    "roomState": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "quiet",
            "active",
            "builder_dense",
            "newcomer_wave",
            "noisy",
            "mixed",
            "tense"
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "momentumHint": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "starting",
            "building",
            "focused",
            "drifting",
            "repetitive",
            "cooling",
            "unclear",
            "dormant",
            "weak",
            "emerging",
            "fragmented",
            "noisy"
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "communityName": {
      "type": "string",
      "maxLength": 200,
      "default": ""
    },
    "communityIdentity": {
      "type": "string",
      "maxLength": 1000,
      "default": ""
    },
    "communityNarrative": {
      "type": "string",
      "maxLength": 2000,
      "default": ""
    },
    "communityFocus": {
      "type": "string",
      "maxLength": 1000,
      "default": ""
    },
    "ecosystemContext": {
      "type": "string",
      "maxLength": 2000,
      "default": ""
    },
    "officialLinks": {
      "type": "string",
      "maxLength": 3000,
      "default": ""
    }
  }
}