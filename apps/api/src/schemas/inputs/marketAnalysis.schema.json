{
  "$id": "marketAnalysisInput",
  "type": "object",
  "required": ["symbol", "market", "intelligence"],
  "additionalProperties": false,
  "properties": {
    "symbol": { "type": "string" },

    "market": {
      "type": "object",
      "required": ["price"],
      "properties": {
        "price": { "type": "number" },
        "candles": {
          "type": "array"
        }
      }
    },

    "intelligence": {
      "type": "object",
      "required": ["regime", "bias"],
      "properties": {
        "regime": { "type": "string" },
        "bias": { "type": "string" }
      }
    }
  }
}