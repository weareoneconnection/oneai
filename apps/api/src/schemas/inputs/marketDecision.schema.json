{
  "type": "object",
  "required": ["symbol", "market", "intelligence", "analysis"],
  "properties": {
    "symbol": { "type": "string" },

    "market": {
      "type": "object",
      "properties": {
        "price": { "type": "number" }
      }
    },

    "intelligence": {
      "type": "object",
      "required": ["regime", "bias", "confidence"],
      "properties": {
        "regime": { "type": "string" },
        "bias": { "type": "string" },
        "confidence": { "type": "number" }
      }
    },

    "analysis": {
      "type": "object",
      "required": ["trend", "structure", "momentum"],
      "properties": {
        "trend": { "type": "string" },
        "structure": { "type": "string" },
        "momentum": { "type": "string" },
        "support": { "type": "number" },
        "resistance": { "type": "number" }
      }
    }
  }
}