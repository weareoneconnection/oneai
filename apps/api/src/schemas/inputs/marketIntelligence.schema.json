{
  "type": "object",
  "required": ["symbol", "timeframe", "market"],
  "additionalProperties": false,
  "properties": {
    "symbol": { "type": "string" },
    "timeframe": { "type": "string" },
    "market": {
      "type": "object",
      "required": ["symbol"],
      "properties": {
        "symbol": { "type": "string" },
        "timeframe": { "type": "string" },
        "price": { "type": "number" },
        "volume24h": { "type": "number" },
        "candles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ts", "open", "high", "low", "close", "volume"],
            "properties": {
              "ts": { "type": "number" },
              "open": { "type": "number" },
              "high": { "type": "number" },
              "low": { "type": "number" },
              "close": { "type": "number" },
              "volume": { "type": "number" }
            },
            "additionalProperties": true
          }
        },
        "extra": { "type": "object" }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object"
    }
  }
}