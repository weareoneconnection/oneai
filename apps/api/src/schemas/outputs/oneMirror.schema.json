{
  "$id": "oneMirrorOutput",
  "type": "object",
  "required": [
    "worldType",
    "summary",
    "shockLine",
    "consequences",
    "scores",
    "socialPost"
  ],
  "properties": {
    "worldType": {
      "type": "string",
      "enum": [
        "fragmented-collapse",
        "guarded-tribalism",
        "cold-efficiency-state",
        "extractive-economy",
        "hyper-competitive-order",
        "cooperative-civilization",
        "compassion-network",
        "resilient-open-world"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "shockLine": {
      "type": "string",
      "minLength": 8,
      "maxLength": 80
    },
    "consequences": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 8,
        "maxLength": 120
      }
    },
    "scores": {
      "type": "object",
      "required": [
        "trust",
        "cooperation",
        "empathy",
        "stability",
        "conflict",
        "openness",
        "extraction",
        "longTermism"
      ],
      "properties": {
        "trust": { "type": "number", "minimum": 0, "maximum": 100 },
        "cooperation": { "type": "number", "minimum": 0, "maximum": 100 },
        "empathy": { "type": "number", "minimum": 0, "maximum": 100 },
        "stability": { "type": "number", "minimum": 0, "maximum": 100 },
        "conflict": { "type": "number", "minimum": 0, "maximum": 100 },
        "openness": { "type": "number", "minimum": 0, "maximum": 100 },
        "extraction": { "type": "number", "minimum": 0, "maximum": 100 },
        "longTermism": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "socialPost": {
      "type": "object",
      "required": ["hook", "body", "cta"],
      "properties": {
        "hook": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120
        },
        "body": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "cta": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}