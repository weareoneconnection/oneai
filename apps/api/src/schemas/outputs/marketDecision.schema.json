{
  "$id": "marketDecisionOutput",
  "type": "object",
  "required": ["action", "confidence", "reason"],
  "additionalProperties": false,
  "properties": {
    "action": {
      "type": "string",
      "enum": ["BUY", "SELL", "HOLD"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "reason": {
      "type": "string",
      "minLength": 5
    },
    "entry": {
      "type": "number"
    },
    "stopLoss": {
      "type": "number"
    },
    "takeProfit": {
      "type": "number"
    },
    "summary": {
      "type": "string"
    }
  }
}