{
  "$id": "marketAnalysisOutput",
  "type": "object",
  "required": ["marketState", "summary", "levels", "setup"],
  "additionalProperties": false,
  "properties": {
    "marketState": {
      "type": "object",
      "required": ["trend", "structure", "volatility", "bias", "confidence"],
      "additionalProperties": false,
      "properties": {
        "trend": {
          "type": "string",
          "enum": ["bullish", "bearish", "neutral", "mixed"]
        },
        "structure": {
          "type": "string",
          "enum": [
            "breakout",
            "trend_continuation",
            "range",
            "compression",
            "reversal_watch",
            "distribution",
            "accumulation"
          ]
        },
        "volatility": {
          "type": "string",
          "enum": ["low", "normal", "high", "expanding"]
        },
        "bias": {
          "type": "string",
          "enum": ["long", "short", "wait"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 5
    },
    "levels": {
      "type": "object",
      "required": ["support", "resistance"],
      "additionalProperties": false,
      "properties": {
        "support": {
          "type": "array",
          "items": { "type": "number" }
        },
        "resistance": {
          "type": "array",
          "items": { "type": "number" }
        },
        "invalidation": {
          "type": "number"
        },
        "triggerZone": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      }
    },
    "setup": {
      "type": "object",
      "required": ["type", "direction", "timeHorizon", "confidence"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "trend_follow",
            "breakout",
            "pullback",
            "mean_reversion",
            "early_trend",
            "no_trade"
          ]
        },
        "direction": {
          "type": "string",
          "enum": ["long", "short", "neutral"]
        },
        "entryLogic": {
          "type": "string"
        },
        "stopLogic": {
          "type": "string"
        },
        "takeProfitLogic": {
          "type": "string"
        },
        "timeHorizon": {
          "type": "string",
          "enum": ["scalp", "intraday", "swing"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "momentum": {
          "type": "string",
          "enum": ["bullish", "bearish", "fading", "mixed"]
        },
        "volumeCondition": {
          "type": "string",
          "enum": ["supportive", "weak", "elevated", "abnormal"]
        },
        "riskCondition": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        }
      }
    }
  }
}