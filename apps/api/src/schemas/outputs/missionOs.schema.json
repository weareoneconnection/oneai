{
  "$id": "missionOsOutput",
  "type": "object",
  "required": [
    "mission_title",
    "mission_type",
    "difficulty",
    "estimated_time_minutes",
    "objective",
    "first_action",
    "success_criteria",
    "steps",
    "execution",
    "proof",
    "review_policy",
    "reward_structure",
    "ranking_model",
    "anti_sybil_mechanism",
    "growth",
    "economics",
    "risk",
    "recommendedCopy",
    "meta"
  ],
  "properties": {
    "mission_title": { "type": "string" },
    "mission_type": { "type": "string" },
    "difficulty": { "type": "string" },
    "estimated_time_minutes": { "type": "integer" },
    "objective": { "type": "string" },
    "first_action": { "type": "string" },

    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },

    "steps": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string" }
    },

    "execution": {
      "type": "object",
      "required": ["platforms"],
      "properties": {
        "platforms": { "type": "array", "items": { "type": "string" } }
      }
    },

    "review_policy": {
      "type": "object",
      "required": ["reviewMode"]
    },

    "reward_structure": {
      "type": "object",
      "required": ["budgetCap"]
    },

    "growth": {
      "type": "object",
      "required": ["enableReferral"]
    },

    "recommendedCopy": {
      "type": "object",
      "required": ["tweet_zh", "tweet_en", "hashtags", "cta"]
    },

    "meta": {
      "type": "object",
      "required": ["schema_version"]
    }
  }
}